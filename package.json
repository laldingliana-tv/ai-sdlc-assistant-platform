{
  "name": "@ai-sdlc/source",
  "version": "0.0.0",
  "private": true,
  "description": "AI SDLC Assistant Platform — AI-powered software development lifecycle orchestration",
  "license": "UNLICENSED",
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "nx run-many -t serve --projects=api,web",
    "build": "nx run-many -t build",
    "lint": "nx run-many -t lint",
    "test": "nx run-many -t test",
    "test:e2e": "nx run-many -t e2e",
    "typecheck": "nx run-many -t typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "clean": "rm -rf node_modules dist tmp .nx"
  },
  "dependencies": {
    "@langchain/core": "^1.1.48",
    "@langchain/langgraph": "^1.3.3",
    "@langchain/openai": "^1.4.7"
