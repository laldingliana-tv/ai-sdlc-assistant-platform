    "@nx/vite": "22.7.5",
    "@nx/vitest": "22.7.5",
    "eslint": "^9.27.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jiti": "2.4.2",
    "lint-staged": "^15.5.2",
    "nx": "22.7.5",
