  "devDependencies": {
    "@nx/eslint": "19.8.0",
    "@nx/eslint-plugin": "^19.8.0",
    "@nx/js": "19.8.0",
    "@nx/nest": "19.8.0",
    "@nx/next": "19.8.0",
    "@nx/vite": "19.8.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "nx": "19.8.0",
    "prettier": "^3.8.3",
    "typescript": "~5.5.4",
    "vitest": "^1.6.0"
  }
