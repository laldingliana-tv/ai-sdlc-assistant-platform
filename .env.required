# Required Environment Variables
# Copy this file to .env and fill in values
# The app will start without these, but features will be limited.

# --- Database (required for full functionality) ---
DATABASE_URL=postgresql://ai_sdlc:ai_sdlc_dev@localhost:5432/ai_sdlc

# --- Auth (required for protected endpoints) ---
JWT_SECRET=change-me-in-production-min-16-chars

# --- AI Provider (at least one needed to run agents) ---
# Pick one or more:
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# --- Observability (optional - telemetry disabled if missing) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- MCP Providers (optional - for code retrieval integrations) ---
GITHUB_TOKEN=
JIRA_BASE_URL=
JIRA_API_TOKEN=
