{
  "compileOnSave": false,
  "compilerOptions": {
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "paths": {
      "@ai-sdlc/shared/types": ["./libs/shared/types/src/index.ts"],
      "@ai-sdlc/shared/schemas": ["./libs/shared/schemas/src/index.ts"],
      "@ai-sdlc/shared/constants": ["./libs/shared/constants/src/index.ts"],
      "@ai-sdlc/shared/prompts": ["./libs/shared/prompts/src/index.ts"],
      "@ai-sdlc/infra/telemetry": ["./libs/infra/telemetry/src/index.ts"],
      "@ai-sdlc/infra/logging": ["./libs/infra/logging/src/index.ts"],
      "@ai-sdlc/infra/auth": ["./libs/infra/auth/src/index.ts"],
      "@ai-sdlc/infra/database": ["./libs/infra/database/src/index.ts"],
      "@ai-sdlc/infra/governance": ["./libs/infra/governance/src/index.ts"],
      "@ai-sdlc/agents/core": ["./libs/agents/core/src/index.ts"],
      "@ai-sdlc/agents/planner": ["./libs/agents/planner/src/index.ts"],
      "@ai-sdlc/agents/retriever": ["./libs/agents/retriever/src/index.ts"],
      "@ai-sdlc/agents/reviewer": ["./libs/agents/reviewer/src/index.ts"],
      "@ai-sdlc/agents/architecture": ["./libs/agents/architecture/src/index.ts"],
      "@ai-sdlc/agents/implementor": ["./libs/agents/implementor/src/index.ts"],
      "@ai-sdlc/agents/a2a": ["./libs/agents/a2a/src/index.ts"],
      "@ai-sdlc/agents/adk": ["./libs/agents/adk/src/index.ts"],
      "@ai-sdlc/mcp": ["./libs/mcp/src/index.ts"],
      "@ai-sdlc/evaluations": ["./libs/evaluations/src/index.ts"],
      "@ai-sdlc/ai/model-gateway": ["./libs/ai/model-gateway/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp", "dist"]
}
