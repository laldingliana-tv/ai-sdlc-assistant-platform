,"source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null},{"id":"impl_plan_v4","label":"Implementation Plan v4 Revised Final","file_type":"document","source_file":"docs/IMPLEMENTATION_PLAN_V4_REVISED_FINAL.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null},{"id":"prd_adr_guide","label":"PRD and ADR Human Guide","file_type":"document","source_file":"docs/PRD_AND_ADR_HUMAN_GUIDE.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null},{"id":"scaffolding_prompt","label":"Project Scaffolding Prompt","file_type":"document","source_file":"docs/ai_sdlc_platform_scaffolding_prompt.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null},{"id":"feedback_recommendations","label":"Final Feedback and Recommendations","file_type":"document","source_file":"docs/final_feedback_recommendations_ai_sdlc_platform.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null},{"id":"phase1_prompt","label":"Phase 1 Implementation Prompt","file_type":"document","source_file":"docs/implementation-phase-1-prompt.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null},{"id":"temporal_orchestration","label":"Temporal Workflow Orchestration","file_type":"rationale","source_file":"docs/IMPLEMENTATION_PLAN_V4_REVISED_FINAL.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Provides workflow durability, retries, approval gates, activity sequencing, and failure recovery. Chosen over autonomous agent chaos to give deterministic workflows, resumability, inspectability, governance. Does NOT own agent reasoning, tool selection, or LLM calls."},{"id":"langgraph_agent_reasoning","label":"LangGraph Agent Reasoning","file_type":"rationale","source_file":"docs/IMPLEMENTATION_PLAN_V4_REVISED_FINAL.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Owns agent reasoning graphs, tool calling, structured output, state machines within a single agent. Does NOT own cross-agent sequencing, durability, or human approval. Chosen because agents need tool calling, structured outputs, and branching/looping."},{"id":"golden_demo_scenario","label":"Golden Demo Scenario","file_type":"rationale","source_file":"docs/IMPLEMENTATION_PLAN_V4_REVISED_FINAL.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Canonical task 'Implement dark mode support across all MFEs' used as the thread pulled through entire system. Every phase prioritizes this single journey working end-to-end. Prevents 'everything 70% done, nothing working'."},{"id":"nx_monorepo_decision","label":"Nx Monorepo Architecture","file_type":"rationale","source_file":"docs/PRD_AND_ADR_HUMAN_GUIDE.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Single repository managed by Nx. Three apps share types and schemas. Nx provides build caching, dependency graph awareness, and affected-only testing. One pnpm install, one repo to clone."},{"id":"no_redis_decision","label":"No Redis Decision","file_type":"rationale","source_file":"docs/IMPLEMENTATION_PLAN_V4_REVISED_FINAL.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Removed from infrastructure to reduce local dev complexity. In-memory rate limiting sufficient for POC. Can be added later if scaling to multiple instances."},{"id":"zod_validation_decision","label":"Zod Schema Validation","file_type":"rationale","source_file":"docs/PRD_AND_ADR_HUMAN_GUIDE.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Single source of truth: define schema once, infer TypeScript types from it. Runtime validation at API boundaries. Contract-first approach essential for AI systems where workflow state evolves rapidly and agent outputs must remain structured."},{"id":"nestjs_fastify_decision","label":"NestJS + Fastify Backend","file_type":"rationale","source_file":"docs/PRD_AND_ADR_HUMAN_GUIDE.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"NestJS provides modular architecture, DI, and good TypeScript support. Fastify chosen over Express for speed (SSE/streaming), better plugin ecosystem for rate limiting and CORS, and schema-based validation."},{"id":"observability_before_orchestration","label":"Observability Before Orchestration","file_type":"rationale","source_file":"docs/final_feedback_recommendations_ai_sdlc_platform.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Introducing telemetry and tracing before workflow orchestration prevents fragmented traces and lost correlation across workflows. Phase 2B exists before Phase 5 for this reason."},{"id":"governance_layer","label":"Governance Layer","file_type":"rationale","source_file":"docs/IMPLEMENTATION_PLAN_V4_REVISED_FINAL.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Approval policies, scope boundaries, and enforcement interfaces. Makes the platform enterprise-oriented rather than experimental. Ties into Temporal HITL approval gate."},{"id":"sdlc_workflow","label":"SDLC Agent Workflow","file_type":"rationale","source_file":"docs/IMPLEMENTATION_PLAN_V4_REVISED_FINAL.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Planner → Retriever → Architecture Review → Approval Gate (HITL) → Implementor → Reviewer. Multi-agent pipeline orchestrated by Temporal with LangGraph reasoning within each agent."},{"id":"planner_agent","label":"Planner Agent","file_type":"rationale","source_file":"docs/IMPLEMENTATION_PLAN_V4_REVISED_FINAL.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null},{"id":"retriever_agent","label":"Retriever Agent","file_type":"rationale","source_file":"docs/IMPLEMENTATION_PLAN_V4_REVISED_FINAL.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null},{"id":"architecture_agent","label":"Architecture Validation Agent","file_type":"rationale","source_file":"docs/IMPLEMENTATION_PLAN_V4_REVISED_FINAL.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null},{"id":"implementor_agent","label":"Implementor Agent","file_type":"rationale","source_file":"docs/IMPLEMENTATION_PLAN_V4_REVISED_FINAL.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null},{"id":"reviewer_agent","label":"Reviewer Agent","file_type":"rationale","source_file":"docs/IMPLEMENTATION_PLAN_V4_REVISED_FINAL.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null},{"id":"mcp_integration","label":"Model Context Protocol Integration","file_type":"rationale","source_file":"docs/IMPLEMENTATION_PLAN_V4_REVISED_FINAL.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Connectors to external tools (GitHub, Docs, Jira). Provider registry pattern with transport abstraction. Agents use MCP tools for context retrieval."},{"id":"evaluation_framework","label":"Evaluation Framework","file_type":"rationale","source_file":"docs/IMPLEMENTATION_PLAN_V4_REVISED_FINAL.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Scoring system for agent output quality. Uses evaluator interface with strategy pattern (relevance, quality evaluators). Feedback recommends starting simpler with direct scoring functions."},{"id":"approval_gate","label":"Human-in-the-Loop Approval Gate","file_type":"rationale","source_file":"docs/IMPLEMENTATION_PLAN_V4_REVISED_FINAL.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Workflow pauses indefinitely until human approves. Implemented via Temporal signals. Ensures humans remain in control before final outputs. Key differentiator from autonomous agent systems."},{"id":"a2a_placeholder","label":"A2A Protocol Placeholder","file_type":"rationale","source_file":"docs/IMPLEMENTATION_PLAN_V4_REVISED_FINAL.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Future interop placeholder only. Typed message contract interface. Nothing active in POC. Feedback recommends collapsing into agents/core until true distributed multi-agent systems exist."},{"id":"adk_placeholder","label":"Google ADK Placeholder","file_type":"rationale","source_file":"docs/IMPLEMENTATION_PLAN_V4_REVISED_FINAL.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Future Google ADK interop placeholder only. Nothing active in POC."}],"edges":[{"source":"nx_json_config","target":"eslintrc_root","relation":"references","confidence":"EXTRACTED","confidence_score":1.0,"source_file":"nx.json","source_location":"lint inputs reference .eslintrc.json","weight":1.0},{"source":"nx_json_config","target":"tsconfig_base","relation":"references","confidence":"EXTRACTED","confidence_score":1.0,"source_file":"nx.json","source_location":"sharedGlobals references tsconfig.base.json","weight":1.0},{"source":"nx_json_config","target":"package_json_root","relation":"shares_data_with","confidence":"EXTRACTED","confidence_score":1.0,"source_file":"nx.json","source_location":"plugins declared in both","weight":0.8},{"source":"pnpm_workspace","target":"package_json_root","relation":"references","confidence":"EXTRACTED","confidence_score":1.0,"source_file":"pnpm-workspace.yaml","source_location":"defines worksp