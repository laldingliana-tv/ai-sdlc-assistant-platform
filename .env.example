# Application
NODE_ENV=development
PORT=3001

# Database
DATABASE_URL=postgresql://ai_sdlc:ai_sdlc_dev@localhost:5432/ai_sdlc

# Auth
JWT_SECRET=change-me-in-production-min-16-chars
JWT_EXPIRES_IN=1h

# Temporal
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=ai-sdlc-tasks

# AI Providers (at least one needed to run agents)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# Observability (optional — telemetry disabled if missing)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
OTEL_EXPORTER_OTLP_ENDPOINT=

# MCP Providers (optional — for code retrieval integrations)
GITHUB_TOKEN=
JIRA_BASE_URL=
JIRA_API_TOKEN=
